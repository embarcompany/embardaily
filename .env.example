# Google Sheets (service account with Editor access to the target spreadsheet)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Embarques
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Preserve line breaks as \n when setting this in a hosting dashboard.
GOOGLE_PRIVATE_KEY=
# Pasta mãe no Drive onde o CRM cria uma pasta por cliente, quando necessário.
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Campaign settings
TOQUE1_DELAY_DAYS=6
REMINDER_DELAY_DAYS=4
GOOGLE_REVIEW_URL=
PORT=3000
APP_BASE_URL=https://crm.seudominio.com
AUDIT_LOG_PATH=./data/embardaily-audit.jsonl
# Proteção simples para a interface (deixe ambos preenchidos na VPS).
CRM_USERNAME=admin
CRM_PASSWORD=

# WhatsApp via Evolution API (the selected provider for this CRM).
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_INSTANCE_NAME=embardaily
EVOLUTION_API_KEY=

# Anthropic is optional; without it, inbound messages are held for human review.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
