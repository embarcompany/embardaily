# Supabase: o banco, arquivos e estado operacional oficiais do EmbarDaily.
# A service role fica somente no servidor/VPS e nunca no JavaScript do navegador.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTERNAL_FUNCTION_SECRET=

# CRM
PORT=3000
APP_BASE_URL=https://crm.seudominio.com
CRM_USERNAME=admin
CRM_PASSWORD=

# Evolution API — usada apenas pelas Edge Functions do Supabase.
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_INSTANCE_NAME=embardaily
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=

# Regras da campanha automática.
TOQUE1_DELAY_DAYS=6
REMINDER_DELAY_DAYS=4
GOOGLE_REVIEW_URL=
