# Supabase (o banco oficial do CRM). A service role nunca vai no navegador.
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
INTERNAL_FUNCTION_SECRET=

# Google Sheets: apenas espelho operacional, escrito pelo Supabase.
# A conta de serviço precisa ser Editor da planilha de destino.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=Embarques
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Preserve line breaks as \n when setting this in a hosting dashboard.
GOOGLE_PRIVATE_KEY=
# Pasta mãe no Drive onde o CRM cria uma pasta por cliente, quando necessário.
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# Campaign settings
TOQUE1_DELAY_DAYS=6
REMINDER_DELAY_DAYS=4
GOOGLE_REVIEW_URL=
PORT=3000
APP_BASE_URL=https://crm.seudominio.com
AUDIT_LOG_PATH=./data/embardaily-audit.jsonl
# Proteção simples para a interface (deixe ambos preenchidos na VPS).
CRM_USERNAME=admin
CRM_PASSWORD=

# WhatsApp via Evolution API (the selected provider for this CRM).
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_INSTANCE_NAME=embardaily
EVOLUTION_API_KEY=
# Se preenchido, a Evolution precisa enviar este mesmo valor no header x-evolution-secret.
EVOLUTION_WEBHOOK_SECRET=

# Anthropic is optional; without it, inbound messages are held for human review.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
